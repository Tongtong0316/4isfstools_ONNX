{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Macaron Singer",
  "version": "1.0.2",
  "identifier": "com.macaron.singer",
  "build": {
    "beforeDevCommand": "npm run build && npm run preview -- --host 127.0.0.1 --port 4173 --strictPort",
    "devUrl": "http://127.0.0.1:4173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Macaron Singer",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "publisher": "Tongtong",
    "copyright": "© 2026 Tongtong",
    "targets": "all",
    "resources": [
      "python/python-standalone.tar.gz",
      "../runtime-manifest.json",
      "models/onnx/UVR_MDXNET_9482.onnx"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    },
    "icon": [
      "icons/icon.icns",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
